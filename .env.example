# Copia este archivo a `.env.local` (desarrollo) o configura las mismas variables en Netlify/Vercel.
# No rellenes este archivo con datos reales y no lo subas con secretos: solo placeholders.

# Supabase (proyecto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor (nunca NEXT_PUBLIC_*). Necesaria para operaciones que bypassan RLS con cuidado.
SUPABASE_SERVICE_ROLE_KEY=

# true = datos mock sin Supabase; false = Supabase real
NEXT_PUBLIC_USE_MOCK=false
